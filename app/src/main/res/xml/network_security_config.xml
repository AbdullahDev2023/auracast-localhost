<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Allow plain-HTTP to localhost only.
        The dev Node server runs on http://localhost:7000 — without this, Android's
        default "no cleartext" policy throws UnknownServiceException at download time.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- Android emulator host alias for the dev machine -->
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
    <!-- All other traffic must be HTTPS -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
