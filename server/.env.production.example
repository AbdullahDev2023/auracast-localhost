NODE_ENV=production
PORT=7000
FIREBASE_DB_URL=https://auracast-df815-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_DB_SECRET=
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/auracast-service-account.json
WS_PING_INTERVAL_MS=30000
STALE_THRESHOLD_MS=90000
STALE_CHECK_MS=15000
STATS_INTERVAL_MS=2000
CHANNEL_GRACE_MS=300000
SERVER_VOLUME_GAIN=3.0
LOG_LEVEL=INFO
LOG_FORMAT=json
RATE_LIMIT_ENABLED=true
RATE_WINDOW_MS=10000
MAX_REQUESTS_PER_WINDOW=240
SHUTDOWN_TIMEOUT_MS=10000
PUBLIC_HOST=https://cast.visioncoachinginstitute.online
