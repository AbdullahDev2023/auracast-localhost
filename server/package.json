{
  "name": "auracast-server",
  "version": "6.0.0",
  "description": "AuraCast — Android to browser live audio relay with typed modular services",
  "main": "dist/main.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:local": "npm run build && node dist/main.js",
    "dev": "nodemon --watch src --ext ts --signal SIGTERM --exec \"npm run build && node dist/main.js\"",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test test/**/*.test.js",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "firebase-admin": "^12.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "eslint": "^9.22.0",
    "nodemon": "^3.1.10",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
