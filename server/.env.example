# AuraCast Server — Local Environment Configuration
# Copy this file to .env for local development.
# Secrets should come from local files or CI secrets, never from committed source.

NODE_ENV=development
PORT=7000

# Realtime Database URL (matches google-services.json)
FIREBASE_DB_URL=https://auracast-df815-default-rtdb.asia-southeast1.firebasedatabase.app

# Legacy RTDB secret for offline /stream-control fallback.
FIREBASE_DB_SECRET=

# Preferred: point to a local secret file outside source control.
# Default lookup order when unset:
#   1. server/.local/serviceAccount.json
#   2. server/config/serviceAccount.json
FIREBASE_SERVICE_ACCOUNT_PATH=.local/serviceAccount.json

# Alternative to a file path for CI: raw JSON value.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

WS_PING_INTERVAL_MS=70000
STALE_THRESHOLD_MS=90000
STALE_CHECK_MS=15000
STATS_INTERVAL_MS=2000
CHANNEL_GRACE_MS=700000
SERVER_VOLUME_GAIN=3.0

LOG_LEVEL=INFO
LOG_FORMAT=pretty

RATE_LIMIT_ENABLED=false
RATE_WINDOW_MS=10000
MAX_REQUESTS_PER_WINDOW=120

SHUTDOWN_TIMEOUT_MS=10000

# UDP audio relay port — must be reachable from Android device.
# Not supported through ngrok; use a VPS with a public IP or Tailscale for UDP.
UDP_PORT=4001

# ── Audio Cast ────────────────────────────────────────────────────────────────
# Max upload size in megabytes (default 50).
AUDIO_CAST_MAX_SIZE_MB=50
# Auto-delete uploaded audio files after N hours (default 2).
AUDIO_CAST_TTL_HOURS=2
# Storage path relative to server root (default .local/audio).
AUDIO_CAST_STORE_DIR=.local/audio

# ── Public URL (required when Android device is remote / using ngrok) ─────────
# The Android device downloads audio by fetching this base URL.
# If the phone is NOT on the same LAN as the server (e.g. using ngrok or a
# cloud deployment), the server cannot derive the correct URL from request
# headers — set PUBLIC_HOST explicitly.
#
# Accepted formats (with or without scheme):
#   PUBLIC_HOST=https://abc123.ngrok-free.app
#   PUBLIC_HOST=abc123.ngrok-free.app          (https:// is assumed)
#   PUBLIC_HOST=https://auracast.example.com
#
# Leave blank for same-LAN use where x-forwarded-proto / host headers are correct.
PUBLIC_HOST=
